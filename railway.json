{
  "$schema": "https://railway.app/railway.schema.json",
  "services": {
    "backend": {
      "source": ".",
      "build": {
        "builder": "NIXPACKS",
        "buildCommand": "npm run build --workspace=packages/shared && npm run db:generate --workspace=server && npm run build --workspace=server && npm run db:push --workspace=server"
      },
      "deploy": {
        "startCommand": "npm start --workspace=server",
        "healthcheckPath": "/health",
        "healthcheckTimeout": 100,
        "restartPolicyType": "ON_FAILURE"
      }
    },
    "frontend": {
      "source": ".",
      "build": {
        "builder": "NIXPACKS",
        "buildCommand": "npm run build --workspace=packages/shared && npm run build --workspace=client"
      },
      "deploy": {
        "startCommand": "npm run preview --workspace=client",
        "restartPolicyType": "ON_FAILURE"
      }
    }
  }
}
